<style>
  #aiWidgetBtn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #4f6ef7, #7c5cf7);
    color: #fff;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    z-index: 1000;
    box-shadow: 0 6px 20px rgba(79,110,247,0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #aiWidgetBtn:hover { transform: scale(1.07); box-shadow: 0 8px 26px rgba(79,110,247,0.55); }
  #aiWidgetBtn .icon-close { display: none; }
  #aiWidgetBtn.open .icon-ask { display: none; }
  #aiWidgetBtn.open .icon-close { display: block; }

  #aiPanel {
    display: none;
    position: fixed;
    bottom: 92px;
    right: 24px;
    z-index: 1001;
    width: 380px;
    max-width: calc(100vw - 32px);
  }
  #aiPanel.active {
    display: block;
    animation: aiPanelIn 0.22s ease-out;
  }
  @keyframes aiPanelIn {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  #aiPanelContent {
    background: #16162a;
    color: #e1e1e1;
    border-radius: 18px;
    border: 1px solid #2a2a4a;
    box-shadow: 0 16px 48px rgba(0,0,0,0.5);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  #aiPanelHeader {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px;
    background: linear-gradient(135deg, #4f6ef7, #7c5cf7);
  }
  #aiPanelHeader h2 {
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }
  #aiPanelHeader span {
    display: block;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.8);
    margin-top: 2px;
  }
  #closePanel {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: none;
    width: 26px;
    height: 26px;
    border-radius: 9999px;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  #closePanel:hover { background: rgba(255,255,255,0.3); }

  #aiPanelBody {
    padding: 16px;
    overflow-y: auto;
  }

  #queryWrap {
    display: flex;
    gap: 8px;
  }
  #userQuery {
    flex: 1;
    background: #20203a;
    color: #fff;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid #333;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }
  #userQuery:focus { border-color: #7c9ef8; }

  #askBtn {
    padding: 10px 16px;
    background: #4f6ef7;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  #askBtn:hover:not(:disabled) { background: #3a57d4; }
  #askBtn:disabled { opacity: 0.5; cursor: default; }

  #aiResponse {
    background: #111128;
    padding: 12px;
    margin-top: 12px;
    max-height: 280px;
    overflow-y: auto;
    border: 1px solid #2a2a4a;
    border-radius: 10px;
    white-space: pre-wrap;
    font-size: 0.85rem;
    line-height: 1.6;
    display: none;
  }
  #aiResponse.visible { display: block; }
  #aiResponse a {
    display: inline-block;
    margin-top: 8px;
    padding: 6px 12px;
    background: #2a2a5a;
    color: #a8bfff;
    border: 1px solid #4a5aaf;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    word-break: break-all;
    transition: background 0.2s, color 0.2s;
  }
  #aiResponse a:hover {
    background: #3a3a7a;
    color: #fff;
    border-color: #7c9ef8;
  }

  .ai-spinner {
    display: inline-block;
    width: 13px; height: 13px;
    border: 2px solid #ffffff44;
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 5px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Mobile: dock as a bottom sheet instead of a floating corner card */
  @media (max-width: 640px) {
    #aiWidgetBtn { bottom: 16px; right: 16px; width: 52px; height: 52px; }
    #aiPanel {
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      max-width: 100%;
    }
    #aiPanel.active { animation: aiPanelInMobile 0.22s ease-out; }
    @keyframes aiPanelInMobile {
      from { opacity: 0; transform: translateY(100%); }
      to   { opacity: 1; transform: translateY(0); }
    }
    #aiPanelContent {
      border-radius: 20px 20px 0 0;
      max-height: 75vh;
    }
  }
</style>

<button id="aiWidgetBtn" aria-label="Open blog assistant">
  <span class="icon-ask">✨</span>
  <span class="icon-close">✕</span>
</button>

<div id="aiPanel" role="dialog" aria-modal="true" aria-labelledby="aiTitle">
  <div id="aiPanelContent">
    <div id="aiPanelHeader">
      <div>
        <h2 id="aiTitle">✨ Blog Assistant</h2>
        <span>Ask about any post on the blog</span>
      </div>
      <button id="closePanel" aria-label="Close">&times;</button>
    </div>

    <div id="aiPanelBody">
      <div id="queryWrap">
        <input
          id="userQuery"
          type="text"
          placeholder="e.g. async programming, Docker, C#…"
          autocomplete="off"
        />
        <button id="askBtn">Ask</button>
      </div>

      <div id="aiResponse" aria-live="polite"></div>
    </div>
  </div>
</div>

<script is:inline>
  // ⚠️ Replace with your Cloudflare Worker URL after deploying
  const WORKER_URL = "https://blog-ai-assistant.adrianbailador.workers.dev";

  const linkStyle = `
    display:inline-block;
    margin:8px 4px 0;
    padding:6px 14px;
    background:#2a2a5a;
    color:#a8bfff;
    border:1px solid #4a5aaf;
    border-radius:6px;
    text-decoration:none;
    font-size:0.85rem;
    font-weight:500;
    word-break:break-all;
  `.replace(/\s+/g, " ").trim();

  const linkHover = `onmouseover="this.style.background='#3a3a7a';this.style.color='#fff';this.style.borderColor='#7c9ef8'"
    onmouseout="this.style.background='#2a2a5a';this.style.color='#a8bfff';this.style.borderColor='#4a5aaf'"`;

  function makeLink(url, label) {
    return `<a href="${url}" target="_blank" rel="noopener" style="${linkStyle}" ${linkHover}>${label}</a>`;
  }

  function linkify(text) {
    // 1. Markdown links [label](url)
    let result = text.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
      (_, label, url) => makeLink(url, label)
    );
    // 2. Bare URLs — strip trailing punctuation
    result = result.replace(/(?<!href=")(https?:\/\/[^\s<>"']+)/g, url => {
      const clean = url.replace(/[).,!?]+$/, "");
      return makeLink(clean, clean);
    });
    // 3. Line breaks
    result = result.replace(/\n/g, "<br>");
    return result;
  }

  (function () {
    let posts = [];
    fetch("/posts.json").then(r => r.json()).then(d => { posts = d; }).catch(() => {});

    const widgetBtn   = document.getElementById("aiWidgetBtn");
    const panel       = document.getElementById("aiPanel");
    const panelContent = document.getElementById("aiPanelContent");
    const closeBtn    = document.getElementById("closePanel");
    const askBtn      = document.getElementById("askBtn");
    const queryInput  = document.getElementById("userQuery");
    const responseBox = document.getElementById("aiResponse");

    function openPanel() {
      panel.classList.add("active");
      widgetBtn.classList.add("open");
      queryInput.focus();
    }
    function closePanel() {
      panel.classList.remove("active");
      widgetBtn.classList.remove("open");
    }
    function togglePanel() {
      panel.classList.contains("active") ? closePanel() : openPanel();
    }

    widgetBtn.addEventListener("click", togglePanel);
    closeBtn.addEventListener("click", closePanel);
    queryInput.addEventListener("keydown", e => { if (e.key === "Enter") askBtn.click(); });

    document.addEventListener("click", (e) => {
      if (!panel.classList.contains("active")) return;
      if (panelContent.contains(e.target) || widgetBtn.contains(e.target)) return;
      closePanel();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && panel.classList.contains("active")) closePanel();
    });

    askBtn.addEventListener("click", async () => {
      const query = queryInput.value.trim();
      if (!query) { queryInput.focus(); return; }

      askBtn.disabled = true;
      askBtn.innerHTML = '<span class="ai-spinner"></span>';
      responseBox.classList.remove("visible");
      responseBox.textContent = "";

      try {
        const res = await fetch(WORKER_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ query, posts }),
        });

        const data = await res.json();

        if (!res.ok) {
          responseBox.textContent = "❌ " + (data.error || `Error ${res.status}`);
        } else {
          responseBox.innerHTML = linkify(data.answer);
        }
        responseBox.classList.add("visible");

      } catch (err) {
        responseBox.textContent = "❌ Network error: " + err.message;
        responseBox.classList.add("visible");
      } finally {
        askBtn.disabled = false;
        askBtn.innerHTML = "Ask";
      }
    });
  })();
</script>
