<style>
  #aiWidgetBtn {
    position: fixed;
    bottom: 28px;
    right: 28px;
    background: #1e1e2e;
    color: #e1e1e1;
    padding: 12px 18px;
    border-radius: 9999px;
    border: 1px solid #333;
    cursor: pointer;
    z-index: 1000;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    transition: background 0.2s, transform 0.15s;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #aiWidgetBtn:hover { background: #2a2a3e; transform: scale(1.04); }

  #aiModal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.65);
    z-index: 1001;
    backdrop-filter: blur(4px);
  }
  #aiModal.active { display: flex; align-items: center; justify-content: center; }

  #aiModalContent {
    background: #1a1a2e;
    color: #e1e1e1;
    width: min(540px, 92vw);
    padding: 28px;
    border-radius: 16px;
    position: relative;
    border: 1px solid #2a2a4a;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
  }

  #aiModalContent h2 {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: #fff;
  }

  #queryWrap {
    display: flex;
    gap: 10px;
  }
  #userQuery {
    flex: 1;
    background: #252540;
    color: #fff;
    padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid #333;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }
  #userQuery:focus { border-color: #7c9ef8; }

  #askBtn {
    padding: 10px 18px;
    background: #4f6ef7;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
    white-space: nowrap;
  }
  #askBtn:hover:not(:disabled) { background: #3a57d4; }
  #askBtn:disabled { opacity: 0.5; cursor: default; }

  #aiResponse {
    background: #111128;
    padding: 14px;
    margin-top: 16px;
    max-height: 260px;
    overflow-y: auto;
    border: 1px solid #2a2a4a;
    border-radius: 8px;
    white-space: pre-wrap;
    font-size: 0.9rem;
    line-height: 1.6;
    display: none;
  }
  #aiResponse.visible { display: block; }
  #aiResponse a {
    display: inline-block;
    margin-top: 8px;
    padding: 6px 12px;
    background: #2a2a5a;
    color: #a8bfff;
    border: 1px solid #4a5aaf;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    word-break: break-all;
    transition: background 0.2s, color 0.2s;
  }
  #aiResponse a:hover {
    background: #3a3a7a;
    color: #fff;
    border-color: #7c9ef8;
  }

  #closeModal {
    position: absolute;
    top: 12px; right: 14px;
    background: transparent;
    color: #666;
    border: none;
    font-size: 20px;
    cursor: pointer;
    transition: color 0.2s;
  }
  #closeModal:hover { color: #fff; }

  .ai-spinner {
    display: inline-block;
    width: 13px; height: 13px;
    border: 2px solid #ffffff44;
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 5px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<button id="aiWidgetBtn" aria-label="Open AI assistant">✨ Ask something</button>

<div id="aiModal" role="dialog" aria-modal="true" aria-labelledby="aiTitle">
  <div id="aiModalContent">
    <button id="closeModal" aria-label="Close">&times;</button>
    <h2 id="aiTitle">✨ Blog Assistant</h2>

    <div id="queryWrap">
      <input
        id="userQuery"
        type="text"
        placeholder="e.g. async programming, Docker, C#…"
        autocomplete="off"
      />
      <button id="askBtn">Search</button>
    </div>

    <div id="aiResponse" aria-live="polite"></div>
  </div>
</div>

<script is:inline>
  // ⚠️ Replace with your Cloudflare Worker URL after deploying
  const WORKER_URL = "https://blog-ai-assistant.adrianbailador.workers.dev";

  const linkStyle = `
    display:inline-block;
    margin:8px 4px 0;
    padding:6px 14px;
    background:#2a2a5a;
    color:#a8bfff;
    border:1px solid #4a5aaf;
    border-radius:6px;
    text-decoration:none;
    font-size:0.85rem;
    font-weight:500;
    word-break:break-all;
  `.replace(/\s+/g, " ").trim();

  const linkHover = `onmouseover="this.style.background='#3a3a7a';this.style.color='#fff';this.style.borderColor='#7c9ef8'"
    onmouseout="this.style.background='#2a2a5a';this.style.color='#a8bfff';this.style.borderColor='#4a5aaf'"`;

  function makeLink(url, label) {
    return `<a href="${url}" target="_blank" rel="noopener" style="${linkStyle}" ${linkHover}>${label}</a>`;
  }

  function linkify(text) {
    // 1. Markdown links [label](url)
    let result = text.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
      (_, label, url) => makeLink(url, label)
    );
    // 2. Bare URLs — strip trailing punctuation
    result = result.replace(/(?<!href=")(https?:\/\/[^\s<>"']+)/g, url => {
      const clean = url.replace(/[).,!?]+$/, "");
      return makeLink(clean, clean);
    });
    // 3. Line breaks
    result = result.replace(/\n/g, "<br>");
    return result;
  }

  (function () {
    let posts = [];
    fetch("/posts.json").then(r => r.json()).then(d => { posts = d; }).catch(() => {});

    const widgetBtn   = document.getElementById("aiWidgetBtn");
    const modal       = document.getElementById("aiModal");
    const closeBtn    = document.getElementById("closeModal");
    const askBtn      = document.getElementById("askBtn");
    const queryInput  = document.getElementById("userQuery");
    const responseBox = document.getElementById("aiResponse");

    function openModal()  { modal.classList.add("active"); queryInput.focus(); }
    function closeModal() {
      modal.classList.remove("active");
      responseBox.classList.remove("visible");
      responseBox.textContent = "";
      queryInput.value = "";
    }

    widgetBtn.addEventListener("click", openModal);
    closeBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", e => { if (e.target === modal) closeModal(); });
    queryInput.addEventListener("keydown", e => { if (e.key === "Enter") askBtn.click(); });

    askBtn.addEventListener("click", async () => {
      const query = queryInput.value.trim();
      if (!query) { queryInput.focus(); return; }

      askBtn.disabled = true;
      askBtn.innerHTML = '<span class="ai-spinner"></span>';
      responseBox.classList.remove("visible");
      responseBox.textContent = "";

      try {
        const res = await fetch(WORKER_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ query, posts }),
        });

        const data = await res.json();

        if (!res.ok) {
          responseBox.textContent = "❌ " + (data.error || `Error ${res.status}`);
        } else {
          responseBox.innerHTML = linkify(data.answer);
        }
        responseBox.classList.add("visible");

      } catch (err) {
        responseBox.textContent = "❌ Network error: " + err.message;
        responseBox.classList.add("visible");
      } finally {
        askBtn.disabled = false;
        askBtn.innerHTML = "Search";
      }
    });
  })();
</script>
