---
type Heading = {
  depth: number
  slug: string
  text: string
}

type Props = {
  headings: Heading[]
  variant?: "mobile" | "desktop"
}

const { headings, variant = "desktop" } = Astro.props
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3)
---

{tocHeadings.length > 2 && (
  <>
    {variant === "mobile" && (
      <details class="lg:hidden mb-6 border border-black/15 dark:border-white/20 rounded-lg">
        <summary class="px-4 py-3 text-xs font-semibold uppercase tracking-widest cursor-pointer text-black/40 dark:text-white/40 select-none">
          On this page
        </summary>
        <ul class="px-4 pb-4 pt-1 space-y-0.5">
          {tocHeadings.map(heading => (
            <li>
              <a
                href={`#${heading.slug}`}
                data-toc-link
                class:list={[
                  "block py-1.5 text-sm leading-snug blend",
                  "text-black/50 dark:text-white/50 hover:text-black hover:dark:text-white",
                  heading.depth === 3 ? "pl-3 text-xs" : "",
                ]}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </details>
    )}

    {variant === "desktop" && (
      <nav id="toc" class="sticky top-28 max-h-[calc(100vh-8rem)] overflow-y-auto">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4 text-black/40 dark:text-white/40">
          On this page
        </p>
        <ul class="space-y-0.5">
          {tocHeadings.map(heading => (
            <li>
              <a
                href={`#${heading.slug}`}
                data-toc-link
                class:list={[
                  "block py-1.5 text-sm leading-snug blend",
                  "text-black/50 dark:text-white/50 hover:text-black hover:dark:text-white",
                  heading.depth === 3 ? "pl-3 text-xs" : "",
                ]}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}
  </>
)}

<style>
  a[data-toc-link][data-active="true"] {
    color: rgba(0, 0, 0, 0.9);
    font-weight: 500;
  }
  :global(.dark) a[data-toc-link][data-active="true"] {
    color: rgba(255, 255, 255, 0.9);
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"))

  if (links.length > 0) {
    const headingIds = links.map(l => l.getAttribute("href")?.slice(1)).filter(Boolean) as string[]
    const headingEls = headingIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[]

    function setActive(id: string | null) {
      links.forEach(link => {
        const href = link.getAttribute("href")?.slice(1)
        link.setAttribute("data-active", href === id ? "true" : "false")
      })
    }

    function getActiveId(): string | null {
      let active: string | null = null
      for (const el of headingEls) {
        if (el.getBoundingClientRect().top <= 120) {
          active = el.id
        }
      }
      return active
    }

    setActive(getActiveId())
    window.addEventListener("scroll", () => setActive(getActiveId()), { passive: true })
  }
</script>
